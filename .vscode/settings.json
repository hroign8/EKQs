{
  "css.customData": [],
  "css.lint.unknownAtRules": "ignore",
  "snyk.advanced.autoSelectOrganization": true,
  "snyk.advanced.organization": "7d51dd70-5894-4b78-b9fe-cabc196be693",

  // Prevent VS Code from watching/indexing large generated folders
  "files.watcherExclude": {
    "**/.next/**": true,
    "**/node_modules/**": true,
    "**/.git/**": true,
    "**/public/uploads/**": true,
    "**/.prisma/**": true
  },
  "files.exclude": {
    "**/.next": true,
    "**/node_modules": true
  },
  "search.exclude": {
    "**/.next/**": true,
    "**/node_modules/**": true,
    "**/.prisma/**": true
  },

  // Limit TypeScript server memory to avoid OOM crashes (8 GB system)
  "typescript.tsserver.maxTsServerMemory": 1024,
  "typescript.disableAutomaticTypeAcquisition": true,
  // Reduce TS background work
  "typescript.tsserver.watchOptions": {
    "watchFile": "useFsEventsOnParentDirectory",
    "watchDirectory": "useFsEvents"
  },

  // ESLint: only run on save, not on every keystroke
  "eslint.run": "onSave",

  // Prevent terminal from buffering excessive output
  "terminal.integrated.scrollback": 500,
  "terminal.integrated.env.osx": {
    "NODE_OPTIONS": "--max-old-space-size=2048"
  },

  // Reduce extension host memory pressure
  "extensions.autoUpdate": false,
  "editor.suggest.preview": false,
  "editor.quickSuggestions": {
    "other": "on",
    "comments": false,
    "strings": false
  },
  "editor.minimap.enabled": false,
  "workbench.editor.limit.enabled": true,
  "workbench.editor.limit.value": 5,

  // Disable heavy features to save memory
  "editor.bracketPairColorization.enabled": false,
  "editor.stickyScroll.enabled": false,
  "editor.linkedEditing": false,
  "editor.codeLens": false,
  "git.autorefresh": false,
  "git.autofetch": false,

  // Disable extensions not needed for this Next.js project
  "go.disableIntellisense": true,
  "python.analysis.autoSearchPaths": false,
  "snyk.yesBackgroundOssNotification": false
}
